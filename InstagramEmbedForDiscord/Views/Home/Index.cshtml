@using InstagramEmbedForDiscord.Controllers;
@using InstagramEmbed.Domain.Entities;
@model string[]
@{
    Layout = null;
    string contentUrl = Model[0];
    string thumbnailUrl = Model[1];
    string url = Model[2];
    bool isPhoto = ViewBag.IsPhoto;

    string postId = ViewBag.PostID;
    int order = ViewBag.Order ?? 1;

    var baseUrl = $"https://{Context.Request.Host}";


    if(contentUrl.Contains("rapidcdn"))
    {
        contentUrl = $"{baseUrl}/offload/{postId}/{order}/";
    }

    Post? post = ViewBag.Post;

    List<InstagramMedia> files = ViewBag.Files ?? new List<InstagramMedia>();

    if (post != null && !Context.Request.Host.Host.EndsWith("d.vxinstagram.com", StringComparison.OrdinalIgnoreCase))
    {
        post.AuthorUsername = null;
        post.Caption = null;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (post?.TrackName == "vxinstagram")
    {
        <link href='~/favicon.png' rel='icon' sizes='svgxsvg' type='image/svg+xml'>
        <link href='~/favicon-32x32.png' rel='icon' sizes='32x32' type='image/png'>
        <link href='~/favicon-16x16.png' rel='icon' sizes='16x16' type='image/png'>
    }
    else
    {
        <link href='~/favicon-note.png' rel='icon' sizes='svgxsvg' type='image/svg+xml'>
        <link href='~/favicon-note-32x32.png' rel='icon' sizes='32x32' type='image/png'>
        <link href='~/favicon-note-16x16.png' rel='icon' sizes='16x16' type='image/png'>
    }


    @if(isPhoto)
    {
        <meta property="og:image" content="@contentUrl" />
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:image" content="@contentUrl" />

        @if (post?.Caption != null)
        {
            <meta property="og:description"
                  content="@post.Caption">
        }
  }
    else
    {
        <meta property="og:type" content="video.other" />
        <meta property="og:video" content="@contentUrl" />

        <meta property="og:video:secure_url" content="@contentUrl" />
        <meta property="og:video:type" content="video/mp4" />
        <meta name="twitter:player" content="@url" />
        <meta name="twitter:card" content="player" />
        
        @* Include thumbnail for apps like Signal that can't play videos *@
        @if(!string.IsNullOrEmpty(thumbnailUrl))
        {
            <meta property="og:image" content="@thumbnailUrl" />
            <meta name="twitter:image" content="@thumbnailUrl" />
        }

    }
    
    <meta property="og:site_name" content="InstagramEmbed @(post != null ? $"❤️ {post.Likes} 💬 {post.Comments}" : "")" />
    <meta property="theme-color" content="#eb4034" />
    <meta property="twitter:title" content="@post?.AuthorUsername" />
    <meta property="twitter:site" content="@post?.AuthorUsername" />
    <link rel="canonical" href="@url" />
    <meta property="og:url" content="@url" />

    
    @if (post?.Caption != null)
    {
        <meta property="og:title" content="@($"{post?.AuthorName} (@{post?.AuthorUsername})")" />

         <link rel="alternate" type="application/json+oembed"
              href="@(baseUrl)/oembed?username=@post.AuthorUsername&desc=@(isPhoto?null:Uri.EscapeDataString(post?.Caption??""))&likescomments=@($" ❤️ {post?.Likes} 💬 {post?.Comments}")" />
        <link rel="alternate" type="application/activity+json"
              href="@(baseUrl)/users/username/statuses/@(Base64Url.Encode(System.Text.Encoding.UTF8.GetBytes(post!.ShortCode+$"&{order}") ))" />
     }
  
    
    <title>@(post?.AuthorUsername != null ? "@" + post.AuthorUsername : "InstagramEmbed")</title>
</head>
<body class="bg-dark text-light position-relative" style="min-height: 100vh;">

    <!-- About the Maker Button -->
    <div class="position-absolute top-0 end-0 p-3" style="z-index: 1000;">
        <button type="button" class="btn btn-sm btn-outline-secondary text-light rounded-circle" data-bs-toggle="modal" data-bs-target="#aboutMakerModal" style="width: 2.5rem; height: 2.5rem; padding: 0;" title="About the Maker">
            <span style="font-size: 1.3rem;">♡</span>
        </button>
    </div>

    <!-- About the Maker Modal -->
    <div class="modal fade" id="aboutMakerModal" tabindex="-1" aria-labelledby="aboutMakerModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-light">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title" id="aboutMakerModalLabel">About the Maker</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <p><strong>InstagramEmbed</strong> by <a href="https://github.com/Lainmode/InstagramEmbedForDiscord" target="_blank" class="text-info">Lainmode</a></p>
                        <p>Twitter: <a href="https://twitter.com/realalita" target="_blank" class="text-info">@@realAlita</a></p>
                    </div>
                    <div class="text-center">
                        <a target="_blank" href="https://www.buymeacoffee.com/alsauce">
                            <img style="height:3rem" src="https://img.buymeacoffee.com/button-api/?text=Buy me a coffee&emoji=☕&slug=alsauce&button_colour=954b89&font_colour=ffffff&font_family=Cookie&outline_colour=ffffff&coffee_colour=FFDD00" />
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex align-items-center justify-content-center" style="min-height: 100vh; padding-top: 2rem; padding-bottom: 2rem;">
    <div class="row g-5 align-items-center w-100 justify-content-center mx-auto px-4">
        @foreach (var item in files)
        {
            var contentUrlForItem = item.url;
            <div class="col-12 col-md-6 col-lg-4">
            <div class="card-body my-auto shadow px-0 py-0 bg-dark text-light border border-secondary pb-3" style="height:fit-content;flex:0;border-radius:1rem">
                <div class="media-container w-100">
                    @if (item.type == "video")
                    {
                        <video class="post-media w-100" style="aspect-ratio:5/6; object-fit:cover;  border-top-left-radius: 1rem; border-top-right-radius:1rem;" controls>
                                <source src="@contentUrlForItem" type="video/mp4">
                Your browser does not support the video tag.
                        </video>
                    }
                    else
                    {
                            <img src="@contentUrlForItem" class="w-100" style="aspect-ratio:5/6; object-fit:cover;  border-top-left-radius: 1rem; border-top-right-radius:1rem;" />
                    }
                </div>
        <div class="content">
            <div class="d-flex flex-column p-3 pb-0 gap-2">
                <button class="btn btn-success"
                        onclick="window.location.href='@contentUrlForItem'">
                    Download
                </button>
                <button class="btn btn-primary"
                        onclick="window.location.href='@url'">
                    View Original Post
                </button>
            </div>
        </div>

    </div>
    </div>
    }
    </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
